{
  "name": "bunny-diary",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "deploy": "bash ./tools/deploy-aliyun-static.sh",
    "deploy:aliyun": "bash ./tools/deploy-aliyun-static.sh",
    "deploy:aliyun:check": "bash ./tools/deploy-aliyun-static.sh --check",
    "prepare:garden-assets": "bash ./tools/prepare-bunny-garden-assets.sh",
    "asset:extract": "python3 tools/extract_nonwhite_regions.py",
    "asset:extract-gui": "python3 tools/garden_asset_extractor_gui.py",
    "calibrate": "python3 tools/calibrate-assets.py",
    "bunny-brain:init": "node tools/bunny-brain-vault.mjs init",
    "bunny-brain:sync": "node tools/bunny-brain-vault.mjs sync",
    "bunny-brain:self-check": "node tools/bunny-brain-vault.mjs self-check",
    "bunny-brain:import": "node tools/bunny-brain-vault.mjs import-anthology"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "html-to-image": "^1.11.13",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.0.0",
    "tailwind-merge": "^2.5.5"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.16",
    "typescript": "^5.7.2",
    "vite": "^8.0.16"
  }
}
