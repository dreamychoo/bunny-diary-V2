# Copy this file to `.deploy.aliyun.env` and fill in your own values.
# Credentials are read from `ossutil` and `aliyun` CLI config, not from this file.

# Required: the OSS bucket that serves this site.
ALIYUN_OSS_BUCKET=mybunnydiary-prod

# Optional: upload the site into a subdirectory instead of bucket root.
ALIYUN_OSS_PREFIX=

# Optional but recommended: public website URL used for CDN cache refresh.
# Use the final public host, not an OSS bucket URL.
ALIYUN_SITE_URL=https://www.mybunnydiary.com

# Optional: pin the OSS upload endpoint if you want to avoid relying on local defaults.
# Example: https://oss-cn-hongkong.aliyuncs.com
ALIYUN_OSS_ENDPOINT=

# Optional: override the CDN directory refresh target.
# If empty, the script derives it from `ALIYUN_SITE_URL` and `ALIYUN_OSS_PREFIX`.
ALIYUN_CDN_REFRESH_DIRECTORY=

# Optional: set to false if you do not want forced CDN refresh.
ALIYUN_REFRESH_FORCE=true
